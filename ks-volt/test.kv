PORT = 8080
LOG_FILE = "bot_log.txt"

// Event listener for heartbeats
on("heartbeat") {
    print("💓 Heartbeat event received!")
    file_write(LOG_FILE, "Heartbeat at " + "now") // Simplified timestamp
}

spawn start_services() {
    print("🚀 Services starting...")

    // Emit heartbeat every 2 seconds
    interval(2000) {
        print("⏲️ Triggering heartbeat...")
        emit("heartbeat")
    }
}

spawn web_server(PORT) {
    serve_html(PORT, "<h1>KS-Volt Live Dashboard</h1>")
}
